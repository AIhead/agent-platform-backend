[Unit]
Description=AI Agent Platform Backend
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/agent-platform-backend
Environment="DATABASE_URL=sqlite+aiosqlite:///./agent_platform.db"
ExecStart=/opt/agent-platform-backend/venv/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
